{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create venv",
      "type": "shell",
      "command": "python -m venv .venv",
      "problemMatcher": []
    },
    {
      "label": "Install requirements",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe -m pip install -r requirements.txt",
      "dependsOn": "Create venv",
      "problemMatcher": []
    },
    {
      "label": "Run app",
      "type": "shell",
      "command": ".\\.venv\\Scripts\\python.exe app.py",
      "dependsOn": "Install requirements",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
